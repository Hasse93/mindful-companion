# Copy to .env and fill in. NEVER commit the real .env.

# Database. SQLite (zero-setup) for local dev; a managed Postgres in production.
DATABASE_URL=sqlite:///./dev.db

# LLM provider: "gemini" (free tier, default) or "claude". Leave the matching
# key blank to fall back to canned stub replies.
LLM_PROVIDER=gemini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic / Claude (used when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=
CHAT_MODEL=claude-haiku-4-5-20251001
REPORT_MODEL=claude-haiku-4-5-20251001

# ML models — the committed quantized ONNX models (torch-free, no downloads).
EMOTION_MODEL=./models/emotion-onnx
SENTIMENT_MODEL=./models/sentiment-onnx

# Auth — set a long random string in production.
JWT_SECRET=dev-only-change-me-in-production

# Frontend origin(s) for CORS (CORS_ORIGIN_REGEX is also supported in prod).
CORS_ORIGINS=http://localhost:3000

# Set true to skip all model loading + API calls (deterministic stubs).
FAKE_AI=false
