# Copy to .env and fill in. NEVER commit the real .env.

# Database (matches docker-compose.yml)
DATABASE_URL=postgresql+psycopg://mindful:mindful@localhost:5432/mindful

# LLM provider: "gemini" (free tier, default) or "claude". Leave the matching
# key blank to fall back to canned stub replies.
LLM_PROVIDER=gemini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic / Claude (used when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=
CHAT_MODEL=claude-haiku-4-5-20251001
REPORT_MODEL=claude-haiku-4-5-20251001

# ML models (HF hub ids or local paths). Point EMOTION_MODEL at your
# GoEmotions fine-tune once trained.
EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english

# Frontend origin(s) for CORS
CORS_ORIGINS=http://localhost:3000

# Set true to skip all model downloads + API calls (deterministic stubs).
FAKE_AI=false
